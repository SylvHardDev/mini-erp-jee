<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.0">

    <persistence-unit name="miniERP">

        <class>com.mini.erp.model.User</class>
        <class>com.mini.erp.model.Client</class>
        <class>com.mini.erp.model.Product</class>
        <class>com.mini.erp.model.Order</class>
        <class>com.mini.erp.model.OrderLine</class>

        <properties>

            <property name="jakarta.persistence.jdbc.driver"
                      value="org.postgresql.Driver"/>

            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:postgresql://localhost:5432/mini_erp"/>

            <property name="jakarta.persistence.jdbc.user"
                      value="postgres"/>

            <property name="jakarta.persistence.jdbc.password"
                      value="HardevHardev"/>

            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.PostgreSQLDialect"/>

            <property name="hibernate.hbm2ddl.auto"
                      value="update"/>

            <property name="hibernate.show_sql"
                      value="true"/>

        </properties>

    </persistence-unit>
</persistence>